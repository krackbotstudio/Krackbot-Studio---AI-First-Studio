# Copy this file to ".env" in the project root (next to package.json).
# Restart `npm run dev` after any change.

# --- Supabase (required for CMS + site data) ---
# Dashboard: https://supabase.com/dashboard → your project → Project Settings → API
#
# 1) "Project URL" → VITE_SUPABASE_URL  (https://xxxxx.supabase.co — no typo, same project as your DB)
# 2) "Project API keys" → anon public → VITE_SUPABASE_ANON_KEY  (long jwt; NOT service_role)
#
# There are no separate "CMS credentials" in .env. CMS login uses Supabase Auth (email/password
# created under Authentication → Users). Database RLS is fixed by running SQL migrations in the
# Supabase SQL Editor (see supabase/migrations/).

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional
# VITE_QUICK_BUILD_LANDING_DELIVERY_URL=
